# AWS Configuration
AWS_REGION=us-east-1
AWS_PROFILE=default

# General / Fallback Agent
AGENT_ID=your-general-agent-id
AGENT_ALIAS_ID=your-general-agent-alias-id

# Order Management Agent
ORDER_AGENT_ID=your-order-agent-id
ORDER_AGENT_ALIAS_ID=your-order-agent-alias-id

# Support Agent
SUPPORT_AGENT_ID=your-support-agent-id
SUPPORT_AGENT_ALIAS_ID=your-support-agent-alias-id

# Billing Agent
BILLING_AGENT_ID=your-billing-agent-id
BILLING_AGENT_ALIAS_ID=your-billing-agent-alias-id

# Step Functions
STATE_MACHINE_ARN=arn:aws:states:us-east-1:YOUR_ACCOUNT_ID:stateMachine:enterprise-agent-workflow
